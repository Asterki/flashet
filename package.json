{
    "name": "flashet",
    "private": true,
    "version": "0.0.0",
    "type": "commonjs",
    "scripts": {
        "preview": "vite preview",
        "lint": "eslint . --fix",
        "test": "echo no tests yet",
        "build": "npm-run-all build:*",
        "build:client": "tsc && vite build",
        "build:server": "tsc -p ./server/tsconfig.json",
        "dev:client": "vite",
        "dev:server": "cross-env NODE_ENV=development nodemon ./server/index.ts",
        "production": "cross-env rm -r ./build  && npm run lint && npm run build && npm run start",
        "start": "cross-env NODE_ENV=production node ./build/server/index.js",
        "prepare": "husky install"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^1.9.2",
        "@types/locale": "^0.1.1",
        "axios": "^1.2.3",
        "bcrypt": "^5.1.0",
        "chalk": "^4.0.0",
        "connect-mongo": "^4.6.0",
        "cors": "^2.8.5",
        "cross-env": "^7.0.3",
        "dotenv": "^16.0.3",
        "express": "^4.18.2",
        "express-rate-limit": "^6.7.0",
        "express-session": "^1.17.3",
        "framer-motion": "^8.5.0",
        "helmet": "^6.0.1",
        "locale": "^0.1.0",
        "mongoose": "^6.8.4",
        "npm": "^9.4.1",
        "npm-run-all": "^4.1.5",
        "passport": "^0.6.0",
        "passport-local": "^1.0.0",
        "passport-local-mongoose": "^7.1.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-helmet": "^6.1.0",
        "react-redux": "^8.0.5",
        "react-router-dom": "^6.6.2",
        "sass": "^1.57.1",
        "validator": "^13.7.0",
        "zod": "^3.20.2"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.0",
        "@types/cors": "^2.8.13",
        "@types/express": "^4.17.16",
        "@types/express-session": "^1.17.5",
        "@types/passport-local": "^1.0.35",
        "@types/react": "^18.0.26",
        "@types/react-dom": "^18.0.9",
        "@types/react-helmet": "^6.1.6",
        "@types/validator": "^13.7.10",
        "@typescript-eslint/eslint-plugin": "^5.48.2",
        "@typescript-eslint/parser": "^5.48.2",
        "@vitejs/plugin-react": "^3.0.0",
        "cypress": "^12.5.1",
        "eslint": "^8.32.0",
        "eslint-config-prettier": "^8.6.0",
        "eslint-plugin-react": "^7.32.1",
        "eslint-plugin-react-hooks": "^4.6.0",
        "nodemon": "^2.0.20",
        "typescript": "^4.9.3",
        "vite": "^4.0.0"
    }
}
